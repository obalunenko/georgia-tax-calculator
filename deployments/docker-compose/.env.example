# Copy this file to .env and fill in your Telegram bot token.
# You can create a bot and obtain a token via https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Optional: debug, info, warn, error, fatal (default: info)
TELEGRAM_BOT_LOG_LEVEL=info
# Optional: path to persisted user IDs file (default: users.json)
USER_STORE_PATH=users.json
